   "source": [
    "from langgraph.graph import StateGraph,START, END\n",
    "from typing import TypedDict,NotRequired\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "c4e0e6a1",
   "metadata": {},
   "outputs": [],
   "source": [
    "llm=ChatGoogleGenerativeAI(model=\"gemini-2.5-flash\",temperature=0.7)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "0538a4ff",
   "metadata": {},
   "outputs": [],
   "source": [
    "class SimpleLlmState(TypedDict):\n",
    "    input: str\n",
    "    output: NotRequired[str]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "3d5eb448",
   "metadata": {},
   "outputs": [],
   "source": [
    "def qa_llm(state: SimpleLlmState) -> dict:\n",
    "    prompt = f\"Answer the following question in plain text without any markdown formatting: {state['input']}\"\n",
    "    response = llm.invoke(prompt)\n",
    "    return {\"output\": response.content}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "0ca0226d",
   "metadata": {},
   "outputs": [],
   "source": [
    "graph = StateGraph(SimpleLlmState)\n",
    "\n",
    "graph.add_node(\"qa_llm\", qa_llm)\n",
    "graph.add_edge(START, \"qa_llm\")\n",
    "graph.add_edge(\"qa_llm\", END)\n",
    "\n",
    "workflow = graph.compile()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "f48b0cec",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The capital of France is Paris.\n"
     ]
    }
   ],
   "source": [
    "result = workflow.invoke({\"input\": \"What is the capital of France?\"})\n",
    "print(result[\"output\"])"
    "\n",
    "# Manually clean the markdown from the string using Python\n",
    "clean_output = result[\"output\"].replace(\"**\", \"\")\n",
    "print(clean_output)"
   ]
  }
 ],
